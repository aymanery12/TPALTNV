# Copier ce fichier en .env et remplir les vraies valeurs
# Ne jamais committer .env !

# ===== Base de donnees MySQL =====
DB_URL=jdbc:mysql://localhost:3306/bookstore_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===== JWT (minimum 32 caracteres) =====
JWT_SECRET=your_jwt_secret_minimum_32_characters_long

# ===== API Gemini (Google AI Studio) =====
GEMINI_API_KEY=your_gemini_api_key

# ===== SMTP Gmail (utiliser un App Password, pas le mot de passe principal) =====
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
